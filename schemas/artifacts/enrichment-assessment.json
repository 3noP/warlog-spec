{
  "$defs": {
    "AlertVerdict": {
      "description": "Final determination on alert validity.",
      "enum": [
        "undetermined",
        "true_positive",
        "false_positive",
        "benign",
        "suspicious",
        "mixed",
        "needs_review"
      ],
      "title": "AlertVerdict",
      "type": "string"
    },
    "ArtifactCitation": {
      "additionalProperties": false,
      "description": "A pointer to evidence that supports an artifact.\n\nCitations are how downstream review can audit a producer's\nreasoning : \"this MITRE T1078 mapping was supported by event X\nsection Y at score 0.83\". The exact ``source_kind`` vocabulary is\nopen (``alert``, ``log_event``, ``threat_intel_feed``, etc.) ;\nconsumers MUST tolerate kinds they don't recognize.",
      "properties": {
        "sourceId": {
          "description": "Identifier of the supporting source",
          "title": "Sourceid",
          "type": "string"
        },
        "sourceKind": {
          "description": "Type of supporting source",
          "title": "Sourcekind",
          "type": "string"
        },
        "section": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional section or path",
          "title": "Section"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        }
      },
      "required": [
        "sourceId",
        "sourceKind"
      ],
      "title": "ArtifactCitation",
      "type": "object"
    },
    "ArtifactConfidence": {
      "additionalProperties": false,
      "description": "A numeric confidence score paired with a coarse-grained band.\n\nBoth fields are optional so that producers without a probabilistic\nmodel can still emit confidence (band only) and probabilistic\nproducers can emit both. Consumers read whichever is present.",
      "properties": {
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "band": {
          "$ref": "#/$defs/ConfidenceBand",
          "default": "unknown"
        }
      },
      "title": "ArtifactConfidence",
      "type": "object"
    },
    "ArtifactEnvelope": {
      "additionalProperties": false,
      "description": "Canonical envelope every read-side artifact rides in.\n\nThe ``artifact_type`` string identifies WHAT was produced (an\nenrichment, a classification, a MITRE assessment, ...). The\n``subject_*`` fields identify what it's ABOUT (an alert or a\ncase). Producer / confidence / citations carry HOW it was made.\nThe actual payload of the artifact lives outside the envelope \u2014\ntyped assessment classes (``ClassificationAssessment``,\n``MitreAssessment``, ``EnrichmentAssessment``) compose the\nenvelope with their specific payload.\n\nThis is the read-side analogue of :class:`warlog_spec.provider_abi.AuditRow`\non the write side : a uniform envelope shape that audit, review,\nand surface tooling can consume without knowing the producer.",
      "properties": {
        "artifactType": {
          "title": "Artifacttype",
          "type": "string"
        },
        "artifactVersion": {
          "default": "v1",
          "title": "Artifactversion",
          "type": "string"
        },
        "subjectType": {
          "enum": [
            "alert",
            "case"
          ],
          "title": "Subjecttype",
          "type": "string"
        },
        "subjectId": {
          "title": "Subjectid",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ArtifactProducer"
        },
        "generatedAt": {
          "format": "date-time",
          "title": "Generatedat",
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/ArtifactConfidence"
        },
        "reviewState": {
          "$ref": "#/$defs/ArtifactReviewState",
          "default": "pending"
        },
        "citations": {
          "items": {
            "$ref": "#/$defs/ArtifactCitation"
          },
          "title": "Citations",
          "type": "array"
        }
      },
      "required": [
        "artifactType",
        "subjectType",
        "subjectId",
        "producer",
        "generatedAt"
      ],
      "title": "ArtifactEnvelope",
      "type": "object"
    },
    "ArtifactProducer": {
      "additionalProperties": false,
      "description": "Who or what generated an artifact.\n\nThe five kinds map cleanly to the provenance categories that\nmatter for downstream review : human-authored, rule-based,\nML-model-output, LLM-output, or system-internal (e.g. an\nauto-correlator).",
      "properties": {
        "kind": {
          "enum": [
            "llm",
            "rule",
            "ml",
            "human",
            "system"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "ArtifactProducer",
      "type": "object"
    },
    "ArtifactReviewState": {
      "description": "Lifecycle state of a produced artifact through human review.\n\nA connector emits artifacts in ``PENDING`` ; analysts move them\nthrough ``ACCEPTED`` / ``REJECTED``. ``SUPERSEDED`` covers the\ncase where a fresher artifact about the same subject replaces an\nolder one (e.g. a re-enrichment after the IOC verdict flipped).",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "superseded"
      ],
      "title": "ArtifactReviewState",
      "type": "string"
    },
    "ConfidenceBand": {
      "description": "Coarse-grained confidence band used when a numeric score is not the\nright surface (e.g. for human-readable summaries or UI badges).",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "title": "ConfidenceBand",
      "type": "string"
    },
    "EnrichmentAssessmentPayload": {
      "additionalProperties": false,
      "description": "The actual enrichment payload \u2014 what context the lookup added.\n\nEach field is optional so different enrichers can fill different\nslices : a host enricher fills ``asset_criticality`` and\n``user_context`` ; a hash reputation enricher fills\n``threat_intel_hits`` and ``matched_iocs`` ; a behavior enricher\nfills ``anomalies``. The same payload shape carries all of them.",
      "properties": {
        "relatedEntities": {
          "items": {
            "$ref": "#/$defs/NormalizedEntity"
          },
          "title": "Relatedentities",
          "type": "array"
        },
        "matchedIocs": {
          "items": {
            "$ref": "#/$defs/ExtractedIOC"
          },
          "title": "Matchediocs",
          "type": "array"
        },
        "prevalenceSummary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prevalencesummary"
        },
        "assetCriticality": {
          "$ref": "#/$defs/ConfidenceBand",
          "default": "unknown"
        },
        "userContext": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Usercontext"
        },
        "threatIntelHits": {
          "items": {
            "type": "string"
          },
          "title": "Threatintelhits",
          "type": "array"
        },
        "anomalies": {
          "items": {
            "type": "string"
          },
          "title": "Anomalies",
          "type": "array"
        }
      },
      "title": "EnrichmentAssessmentPayload",
      "type": "object"
    },
    "EntityRole": {
      "description": "Role of an entity in an alert/case context.",
      "enum": [
        "principal",
        "target",
        "source",
        "intermediary",
        "observer",
        "related",
        "unknown"
      ],
      "title": "EntityRole",
      "type": "string"
    },
    "EntityType": {
      "description": "Normalized entity type \u2014 12-value canonical taxonomy.",
      "enum": [
        "host",
        "user",
        "ip",
        "domain",
        "url",
        "file",
        "process",
        "email",
        "registry",
        "vulnerability",
        "certificate",
        "other"
      ],
      "title": "EntityType",
      "type": "string"
    },
    "ExtractedIOC": {
      "additionalProperties": false,
      "description": "A canonical indicator-of-compromise reference.\n\nDistinct from :class:`NormalizedEntity` because IOCs carry\nthreat-intel-specific metadata (``maliciousness``, feed\nprovenance, first/last-seen) that doesn't apply to e.g. an\ninternal user or host entity.",
      "properties": {
        "iocType": {
          "$ref": "#/$defs/IOCType"
        },
        "value": {
          "title": "Value",
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/ArtifactConfidence"
        },
        "maliciousness": {
          "$ref": "#/$defs/AlertVerdict",
          "default": "undetermined"
        },
        "sourceFields": {
          "items": {
            "type": "string"
          },
          "title": "Sourcefields",
          "type": "array"
        },
        "firstSeen": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Firstseen"
        },
        "lastSeen": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lastseen"
        },
        "feedId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feedid"
        },
        "feedFreshnessAt": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feedfreshnessat"
        }
      },
      "required": [
        "iocType",
        "value"
      ],
      "title": "ExtractedIOC",
      "type": "object"
    },
    "IOCType": {
      "description": "Indicator of Compromise types.",
      "enum": [
        "ip",
        "ipv6",
        "domain",
        "url",
        "hash_md5",
        "hash_sha1",
        "hash_sha256",
        "email",
        "user",
        "process",
        "registry_key",
        "file_path",
        "certificate",
        "cve",
        "other"
      ],
      "title": "IOCType",
      "type": "string"
    },
    "NormalizedEntity": {
      "additionalProperties": false,
      "description": "A canonical entity reference (host, user, IP, hash, ...).\n\nThe vendor-side identifier is normalized at extraction time into\n``(entity_type, value)`` ; ``role`` distinguishes the entity's\nsemantic role in the alert/case (subject, target, related, ...).\nConnectors producing context artifacts about an entity reference\nit via this shape ; downstream consumers route by ``entity_type``.",
      "properties": {
        "entityType": {
          "$ref": "#/$defs/EntityType"
        },
        "value": {
          "title": "Value",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/EntityRole",
          "default": "unknown"
        },
        "confidence": {
          "$ref": "#/$defs/ArtifactConfidence"
        },
        "sourceFields": {
          "items": {
            "type": "string"
          },
          "title": "Sourcefields",
          "type": "array"
        }
      },
      "required": [
        "entityType",
        "value"
      ],
      "title": "NormalizedEntity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Envelope-wrapped enrichment payload \u2014 the canonical read-side\noutput of an enricher connector. Inherits the canonical\n``envelope`` field from :class:`CanonicalArtifact`.\n\nA connector wrapping VirusTotal, AbuseIPDB, Shodan, GreyNoise, or\nan internal ML model produces this exact shape. The orchestrator\n(or bundle assembler) merges multiple ``EnrichmentAssessment``\ninstances about the same subject without caring which connector\nproduced each.",
  "properties": {
    "envelope": {
      "$ref": "#/$defs/ArtifactEnvelope"
    },
    "payload": {
      "$ref": "#/$defs/EnrichmentAssessmentPayload"
    }
  },
  "required": [
    "envelope",
    "payload"
  ],
  "title": "EnrichmentAssessment",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3noP.github.io/warlog-spec/schemas/draft/artifacts/EnrichmentAssessment.json"
}
