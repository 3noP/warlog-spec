    "next_step_proposal": "proposals/next-step-proposal.json",
    "playbook_candidate_proposal": "proposals/playbook-candidate-proposal.json",
    "investigation_summary_proposal": "proposals/investigation-summary-proposal.json",
    "classification_assessment": "artifacts/classification-assessment.json",
    "mitre_assessment": "artifacts/mitre-assessment.json",
    "enrichment_assessment": "artifacts/enrichment-assessment.json",
    "closure_summary": "artifacts/closure-summary.json",
    "case_return_summary": "artifacts/case-return-summary.json",
    "risk_arbitration": "artifacts/risk-arbitration.json",
    "approval_decision": "artifacts/approval-decision.json"
  }
}
