{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3noP.github.io/warlog-spec/schemas/draft/action-catalog.json",
  "title": "Warlog Spec — canonical action catalog",
  "description": "Per-action metadata (family, reversibility, default approval, default reviewers, optional params schema). Generated from warlog_spec.action_catalog.to_json_manifest().",
  "spec_version": "1.0",
  "actions": {
    "host.isolate": {
      "family": "device",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Isolate a host from the network (containment)."
    },
    "host.unisolate": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Lift host network isolation."
    },
    "host.restart": {
      "family": "device",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Reboot the host (in-memory state lost)."
    },
    "host.collect_artifacts": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Pull a file or memory dump for forensics.",
      "params_schema_ref": "action-params/host.collect_artifacts.json"
    },
    "process.kill": {
      "family": "device",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Kill a running process (orphans children, releases handles)."
    },
    "process.suspend": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Suspend a running process (resumable)."
    },
    "file.quarantine": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Move a file to vendor quarantine (releasable)."
    },
    "file.delete": {
      "family": "device",
      "reversibility": "destructive",
      "default_approval": "manager",
      "default_reviewers": 2,
      "summary": "Permanently delete a file (modulo out-of-band backups)."
    },
    "hash.block": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Add a SHA256 to fleet-wide prevention."
    },
    "user.disable": {
      "family": "identity",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
