    "user.reset_mfa": {
      "family": "identity",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Remove enrolled MFA factors (must re-enroll)."
    },
    "user.revoke_tokens": {
      "family": "identity",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Invalidate all OAuth/refresh tokens."
    },
    "user.reset_password": {
      "family": "identity",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Force admin-initiated password reset."
    },
    "user.expire_password": {
      "family": "identity",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Force password change at next login."
    },
    "user.unlock": {
      "family": "identity",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Clear a user lockout state."
    },
    "user.group_remove": {
      "family": "identity",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Remove user from a (typically privileged) group.",
      "params_schema_ref": "action-params/user.group_remove.json"
    },
    "user.delete": {
      "family": "identity",
      "reversibility": "destructive",
      "default_approval": "manager",
      "default_reviewers": 2,
      "summary": "Permanently delete a user account."
    },
    "email.quarantine": {
      "family": "email",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Move a delivered email to quarantine."
    },
    "email.recall": {
      "family": "email",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Pull a delivered email from recipient inbox (destroys their view)."
    },
    "email.release": {
      "family": "email",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Release a quarantined message back to inbox."
