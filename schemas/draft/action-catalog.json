    "email.block_sender": {
      "family": "email",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Add a sender (email or domain) to the tenant blocklist."
    },
    "email.unblock_sender": {
      "family": "email",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Remove a sender from the tenant blocklist."
    },
    "ip.block": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Block an IP at the network perimeter."
    },
    "ip.unblock": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Remove an IP from the network blocklist."
    },
    "domain.block": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Block a domain at the network perimeter."
    },
    "domain.unblock": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Remove a domain from the network blocklist."
    },
    "url.block": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Block a URL at the network perimeter."
    },
    "url.unblock": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Remove a URL from the network blocklist."
    },
    "hash.unblock": {
      "family": "network",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Remove a SHA256 from fleet-wide prevention."
    },
    "session.terminate": {
      "family": "network",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Drop an active TCP/UDP flow or VPN/ZTNA tunnel.",
      "params_schema_ref": "action-params/session.terminate.json"
    },
    "cert.revoke": {
      "family": "network",
      "reversibility": "destructive",
      "default_approval": "manager",
      "default_reviewers": 2,
      "summary": "Revoke a certificate via CRL/OCSP (must issue new cert)."
    },
    "host.stop": {
      "family": "device",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Stop a compute instance (in-memory state lost, disk preserved)."
    },
    "host.start": {
      "family": "device",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Start a stopped compute instance (inverse of host.stop)."
    },
    "host.delete": {
      "family": "device",
      "reversibility": "destructive",
      "default_approval": "manager",
      "default_reviewers": 2,
      "summary": "Permanently terminate a compute instance."
    },
    "iam.role_detach": {
      "family": "iam",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Detach an IAM role/policy from a principal (in-flight assumed sessions live to expiry).",
      "params_schema_ref": "action-params/iam.role_detach.json"
    },
    "iam.role_attach": {
      "family": "iam",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Attach an IAM role/policy to a principal (inverse of iam.role_detach).",
      "params_schema_ref": "action-params/iam.role_detach.json"
    },
    "iam.credentials_disable": {
      "family": "iam",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Disable an access key / service account credential.",
      "params_schema_ref": "action-params/iam.credentials_disable.json"
    },
    "iam.credentials_enable": {
      "family": "iam",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Re-enable a disabled credential (inverse of iam.credentials_disable).",
      "params_schema_ref": "action-params/iam.credentials_disable.json"
    },
    "iam.credentials_rotate": {
      "family": "iam",
      "reversibility": "destructive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Rotate credentials (old credential gone, consumers must refresh).",
      "params_schema_ref": "action-params/iam.credentials_disable.json"
    },
    "key.disable": {
      "family": "key",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Disable a KMS key (encrypted data inaccessible until re-enabled)."
    },
    "key.enable": {
      "family": "key",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Re-enable a disabled KMS key (inverse of key.disable)."
    },
    "key.rotate": {
      "family": "key",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Rotate a KMS key (version-add ; old versions remain valid for decrypt)."
    },
    "key.schedule_deletion": {
      "family": "key",
      "reversibility": "destructive",
      "default_approval": "manager",
      "default_reviewers": 2,
      "summary": "Schedule a KMS key for permanent deletion after a cooldown.",
      "params_schema_ref": "action-params/key.schedule_deletion.json"
    },
    "bucket.lockdown": {
      "family": "storage",
      "reversibility": "disruptive",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Deny all public/external access to a bucket (active consumers break, reversible)."
    },
    "bucket.unlock": {
      "family": "storage",
      "reversibility": "reversible",
      "default_approval": "senior",
      "default_reviewers": 1,
      "summary": "Remove lockdown artifacts imposed by bucket.lockdown (does not restore prior policy)."
    },
    "alert.acknowledge": {
      "family": "workflow",
      "reversibility": "reversible",
      "default_approval": "none",
      "default_reviewers": 0,
      "summary": "Acknowledge an alert (auto-executable)."
    },
    "case.update_status": {
      "family": "workflow",
      "reversibility": "reversible",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Update the status of a case."
    },
    "playbook.trigger": {
      "family": "workflow",
      "reversibility": "varies",
      "default_approval": "analyst",
      "default_reviewers": 1,
      "summary": "Trigger a playbook (reversibility depends on body)."
    }
  }
}
